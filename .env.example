APP_NAME=Librarian Pro API
APP_ENV=development
APP_DEBUG=false
API_V1_PREFIX=/api/v1

POSTGRES_DB=librarian_pro
POSTGRES_USER=librarian_pro
POSTGRES_PASSWORD=replace-with-a-strong-password
DATABASE_URL=postgresql+psycopg://librarian_pro:replace-with-a-strong-password@db:5432/librarian_pro

JWT_SECRET_KEY=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

DEFAULT_LOAN_PERIOD_DAYS=14
MAX_ACTIVE_LOANS_PER_MEMBER=5
DEFAULT_FINE_RATE_PER_DAY=100.00

# JSON array. Render production must include the Vercel origin without a trailing slash.
BACKEND_CORS_ORIGINS=["https://labpro-seven.vercel.app","http://localhost:8000"]
